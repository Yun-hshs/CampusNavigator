page {
  background: #f5f7fa;
  color: #1f1f1f;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}
.container {
  padding: 24rpx;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}
.primary {
  background: #1677ff;
  color: #fff;
  border-radius: 999rpx;
  margin-bottom: 24rpx;
}
.primary[disabled] {
  background: #91caff;
}
