.route-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.route-summary {
  display: flex;
  text-align: center;
  margin-bottom: 24rpx;
}

.summary-item { flex: 1; }
.summary-value { font-size: 40rpx; font-weight: 700; color: #667eea; }
.summary-label { font-size: 24rpx; color: #999; margin-top: 8rpx; }

.route-steps { border-top: 1rpx solid #f0f0f0; padding-top: 20rpx; }
.step-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.step-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #667eea;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.step-text { font-size: 28rpx; color: #333; line-height: 1.5; }
