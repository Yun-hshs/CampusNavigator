.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 64rpx;
}
.search-clear {
  font-size: 32rpx;
  color: #999;
  padding: 0 16rpx;
}
.search-hint {
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 26rpx;
  margin-top: -8rpx;
}
