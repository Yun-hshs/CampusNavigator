.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #cccccc;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 8rpx 20rpx;
}

.header-count {
  font-size: 26rpx;
  color: #666666;
}

.clear-btn {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
}

.fav-card {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.fav-card:active {
  background: #f9f9f9;
}

.fav-main {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.fav-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 16rpx;
}

.fav-type {
  font-size: 22rpx;
  color: #667eea;
  background: #f0f4ff;
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
}

.fav-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.fav-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.fav-time {
  font-size: 22rpx;
  color: #bbbbbb;
}

.fav-delete {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
}
