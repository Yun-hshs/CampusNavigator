.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #cccccc;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 8rpx 20rpx;
}

.header-count {
  font-size: 26rpx;
  color: #666666;
}

.clear-btn {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
}

.history-card {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.history-card:active {
  background: #f9f9f9;
}

.route-line {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot.green {
  background: #52c41a;
}

.dot.red {
  background: #ff4d4f;
}

.point-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin: 0 12rpx;
}

.route-arrow {
  font-size: 28rpx;
  color: #cccccc;
  margin: 0 8rpx;
}

.route-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.meta-badge {
  font-size: 22rpx;
  color: #667eea;
  background: #f0f4ff;
  border-radius: 20rpx;
  padding: 6rpx 20rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.meta-time {
  font-size: 22rpx;
  color: #bbbbbb;
}

.card-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.action-replay {
  font-size: 24rpx;
  color: #667eea;
  padding: 4rpx 0;
}

.action-delete {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 4rpx 0;
}
