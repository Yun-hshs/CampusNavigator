<view class="home-page">
  <view class="top-panel card">
    <search-bar placeholder="搜索教学楼 / 食堂 / 办公室"
      value="{{keyword}}" showState="{{true}}"
      searching="{{searching}}" empty="{{!results.length}}"
      bind:input="onSearchInput" bind:clear="onClearSearch" />

    <view wx:if="{{results.length}}" class="results-list">
      <poi-card wx:for="{{results}}" wx:key="id"
        id="{{item.id}}" name="{{item.name}}" type="{{item.type}}"
        bind:tap="onTapPoi" />
    </view>
  </view>

  <view class="map-wrap card">
    <map
      id="campusMap"
      class="campus-map"
      longitude="{{mapLongitude}}"
      latitude="{{mapLatitude}}"
      scale="{{mapScale}}"
      markers="{{markers}}"
      polyline="{{polyline}}"
      show-location
      enable-3D="{{true}}"
      enable-zoom="{{true}}"
      enable-rotate="{{false}}"
      show-compass="{{true}}"
      bindmarkertap="onMarkerTap"
    ></map>

    <view class="map-float-card">
      <view class="nav-title">校园实时导航</view>
      <view class="nav-subtitle">已覆盖教学楼、食堂、停车场等核心地点</view>
    </view>
  </view>

  <view class="quick-actions">
    <view class="quick card" data-keyword="教学楼" bindtap="onQuickAction">去教学楼</view>
    <view class="quick card" data-keyword="食堂" bindtap="onQuickAction">去食堂</view>
    <view class="quick card" data-keyword="厕所" bindtap="onQuickAction">找厕所</view>
    <view class="quick card" data-keyword="停车场" bindtap="onQuickAction">找停车位</view>
  </view>
</view>
