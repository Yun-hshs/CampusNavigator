.home-page {
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #eaf3ff 0%, #f7f9fc 52%, #ffffff 100%);
  box-sizing: border-box;
}

.center-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero {
  margin-bottom: 24rpx;
  text-align: center;
}

.school-badge {
  width: 156rpx;
  height: 156rpx;
  margin-bottom: 16rpx;
  border-radius: 50%;
  box-shadow: 0 10rpx 26rpx rgba(33, 80, 137, 0.15);
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #d9e9ff;
  color: #1f6bff;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 42rpx;
  color: #1f2d3d;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #6b7b8d;
}

.glass-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(4px);
}

.top-panel {
  border-radius: 24rpx;
  margin-bottom: 18rpx;
}

.results-list {
  margin-top: 16rpx;
  max-height: 360rpx;
  width: 100%;
  overflow-y: auto;
}

.map-wrap {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  padding: 0;
  box-shadow: 0 16rpx 40rpx rgba(31, 73, 125, 0.12);
}

.campus-map {
  width: 100%;
  height: 760rpx;
}

.map-float-card {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  border-radius: 18rpx;
  padding: 18rpx 22rpx;
  background: rgba(15, 34, 61, 0.72);
  backdrop-filter: blur(8px);
  text-align: center;
}

.nav-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.nav-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.quick-title {
  margin: 4rpx 2rpx 14rpx;
  font-size: 28rpx;
  color: #2b3f56;
  font-weight: 600;
  text-align: center;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.quick {
  padding: 22rpx 8rpx;
  text-align: center;
  font-size: 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #32516f;
  box-shadow: 0 10rpx 24rpx rgba(39, 86, 139, 0.08);
}
