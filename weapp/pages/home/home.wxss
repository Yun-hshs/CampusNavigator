.home-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f7fa;
  overflow: hidden;
}

/* 搜索栏 */
.search-section {
  position: relative;
  z-index: 100;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  flex-shrink: 0;
}

.search-bar {
  display: flex;
  align-items: center;
  height: 80rpx;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: #333333;
}

.placeholder {
  color: #999999;
}

.clear-btn {
  font-size: 28rpx;
  color: #999999;
  padding: 10rpx;
}

/* 搜索结果下拉 */
.results-dropdown {
  position: absolute;
  top: 100rpx;
  left: 24rpx;
  right: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
  max-height: 480rpx;
  overflow-y: auto;
  z-index: 101;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-item:active {
  background: #f5f7fa;
}

.result-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.result-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.result-type {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.search-status {
  position: absolute;
  top: 100rpx;
  left: 24rpx;
  right: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
  z-index: 101;
}

/* 地图区域 - 关键修复 */
.map-wrapper {
  flex: 1;
  position: relative;
  width: 100%;
  overflow: hidden;
}

.campus-map {
  width: 100%;
  height: 100%;
}

/* 底部信息栏 */
.map-info-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
}

.info-left {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.info-right {
  display: flex;
  align-items: center;
}

.building-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 路径信息浮层 */
.route-info {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
  z-index: 50;
}

.route-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.route-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.route-close {
  font-size: 28rpx;
  color: #999999;
  padding: 8rpx;
}

.route-detail {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.route-from,
.route-to {
  font-size: 26rpx;
  color: #333333;
}

.route-arrow {
  margin: 0 16rpx;
  font-size: 24rpx;
  color: #667eea;
}

.route-stats {
  display: flex;
  justify-content: center;
  gap: 32rpx;
}

.route-distance,
.route-time {
  font-size: 24rpx;
  color: #667eea;
  background: #f0f4ff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 收藏按钮 */
.fav-float-btn {
  position: absolute;
  bottom: 120rpx;
  right: 30rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #cccccc;
  z-index: 50;
}

.fav-float-btn:active {
  transform: scale(0.9);
}

.fav-float-btn.active {
  color: #f6d365;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 24rpx 40rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.quick-btn:active {
  background: #f5f7fa;
  transform: scale(0.95);
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.quick-text {
  font-size: 24rpx;
  color: #333333;
}
