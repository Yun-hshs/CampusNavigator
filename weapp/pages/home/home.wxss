.results {
  margin-bottom: 20rpx;
  max-height: 480rpx;
  overflow-y: auto;
}

.map {
  height: 760rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #bbb;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.quick {
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
}
