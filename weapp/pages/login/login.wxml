<view class="login-page">
  <view class="hero">
    <view class="hero-badge">Campus Navigator</view>
    <view class="hero-title">欢迎使用校园导航</view>
    <view class="hero-subtitle">一键登录，快速查找地点并开始智能导航</view>
  </view>

  <view class="login-card">
    <button class="wechat-btn" bindtap="onWechatLogin">微信一键登录</button>
    <button class="guest-btn" bindtap="onGuestMode">先逛逛（游客模式）</button>
    <view class="agreement">登录即表示同意《用户协议》与《隐私政策》</view>
  </view>
</view>
