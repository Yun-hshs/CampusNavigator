.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(165deg, #667eea 0%, #764ba2 100%);
  box-sizing: border-box;
  padding: 60rpx 48rpx;
}

.login-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.15);
}

.icon-emoji {
  font-size: 72rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 按钮区域 */
.btn-section {
  width: 100%;
  margin-bottom: 48rpx;
}

.wechat-btn,
.guest-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
}

.wechat-btn {
  background: #07c160;
  color: #ffffff;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 24rpx rgba(7, 193, 96, 0.3);
}

.wechat-btn::after {
  border: none;
}

.wechat-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.guest-btn {
  background: rgba(255, 255, 255, 0.15);
  color: #ffffff;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.guest-btn::after {
  border: none;
}

.guest-btn:active {
  background: rgba(255, 255, 255, 0.25);
}

/* 协议区域 */
.agreement {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.link {
  color: rgba(255, 255, 255, 0.9);
}
